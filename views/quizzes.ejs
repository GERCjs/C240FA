<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quizzes - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>📝 Quiz Generator</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal">+ Generate Quiz</button>
        </div>

        <!-- Recent Attempts -->
        <% if (typeof attempts !== 'undefined' && attempts.length > 0) { %>
            <h5>Recent Scores</h5>
            <div class="row g-3 mb-4">
                <% attempts.slice(0, 4).forEach(a => { %>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body text-center">
                                <h4 class="<%= a.percentage >= 70 ? 'text-success' : a.percentage >= 50 ? 'text-warning' : 'text-danger' %>">
                                    <%= a.percentage %>%
                                </h4>
                                <small class="text-muted"><%= a.quiz_title %></small>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <!-- Available Quizzes -->
        <h5>Your Quizzes</h5>
        <% if (typeof quizzes !== 'undefined' && quizzes.length > 0) { %>
            <div class="row g-3">
                <% quizzes.forEach(q => { %>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h6><%= q.title %></h6>
                                <p class="text-muted mb-1">
                                    <span class="badge bg-secondary"><%= q.quiz_type.toUpperCase() %></span>
                                    <span class="badge bg-info"><%= q.question_count %> questions</span>
                                </p>
                                <small class="text-muted"><%= new Date(q.created_at).toLocaleDateString() %></small>
                            </div>
                            <div class="card-footer">
                                <a href="/quizzes/<%= q.id %>" class="btn btn-sm btn-primary">Take Quiz</a>
                                <a href="/quizzes/<%= q.id %>/results" class="btn btn-sm btn-outline-secondary">Results</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center text-muted py-5">
                <h4>No quizzes yet</h4>
                <p>Generate your first quiz from your study topics!</p>
            </div>
        <% } %>
    </div>

    <!-- Generate Quiz Modal -->
    <div class="modal fade" id="generateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/quizzes/generate" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Generate Quiz</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <select name="subject" class="form-select" required>
                                <option value="Programming">Programming</option>
                                <option value="Database">Database</option>
                                <option value="AI Prompting">AI Prompting</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Topic</label>
                            <input type="text" name="topic" class="form-control" required placeholder="e.g. Python Basics, SQL SELECT">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Number of Questions</label>
                            <input type="number" name="question_count" class="form-control" value="5" min="3" max="10">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quiz Type</label>
                            <select name="quiz_type" class="form-select">
                                <option value="mcq">Multiple Choice</option>
                                <option value="short_answer">Short Answer</option>
                                <option value="mixed">Mixed</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Generate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
