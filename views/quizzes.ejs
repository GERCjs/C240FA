<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quizzes - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>📝 Quiz Generator</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal">
                + Generate Quiz
            </button>
        </div>

        <!-- Success Message -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Performance Overview -->
        <% if (typeof attempts !== 'undefined' && attempts.length > 0) { %>
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">📊 Recent Performance</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <% attempts.slice(0, 4).forEach(a => { %>
                            <div class="col-md-3 col-6">
                                <div class="card text-center border-0 bg-light">
                                    <div class="card-body py-3">
                                        <h3 class="mb-1 <%= a.percentage >= 70 ? 'text-success' : a.percentage >= 50 ? 'text-warning' : 'text-danger' %>">
                                            <%= a.percentage %>%
                                        </h3>
                                        <small class="text-muted d-block text-truncate"><%= a.quiz_title %></small>
                                        <small class="text-muted"><%= a.score %>/<%= a.total %></small>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Available Quizzes -->
        <h5 class="mb-3">Your Quizzes</h5>
        <% if (typeof quizzes !== 'undefined' && quizzes.length > 0) { %>
            <div class="row g-3">
                <% quizzes.forEach(q => { %>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h6 class="card-title"><%= q.title %></h6>
                                <p class="text-muted mb-2">
                                    <span class="badge bg-secondary"><%= q.quiz_type.toUpperCase() %></span>
                                    <span class="badge bg-info"><%= q.question_count %> questions</span>
                                </p>
                                <small class="text-muted">
                                    Created: <%= new Date(q.created_at).toLocaleDateString() %>
                                </small>
                            </div>
                            <div class="card-footer d-flex justify-content-between align-items-center">
                                <div>
                                    <a href="/quizzes/<%= q.id %>" class="btn btn-sm btn-primary">Take Quiz</a>
                                    <a href="/quizzes/<%= q.id %>/results" class="btn btn-sm btn-outline-secondary">History</a>
                                </div>
                                <form action="/quizzes/<%= q.id %>/delete" method="POST" class="d-inline"
                                      onsubmit="return confirm('Delete this quiz and all attempts?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete quiz">
                                        🗑️
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center text-muted py-5">
                <div class="display-1 mb-3">📝</div>
                <h4>No quizzes yet</h4>
                <p>Generate your first quiz to test your knowledge!</p>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal">
                    Generate Your First Quiz
                </button>
            </div>
        <% } %>
    </div>

    <!-- Generate Quiz Modal -->
    <div class="modal fade" id="generateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/quizzes/generate" method="POST" id="quizForm">
                    <div class="modal-header">
                        <h5 class="modal-title">🧠 Generate Quiz</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Subject *</label>
                            <select name="subject" class="form-select" required>
                                <option value="">-- Select Subject --</option>
                                <option value="Programming">Programming</option>
                                <option value="Database">Database</option>
                                <option value="AI Prompting">AI Prompting</option>
                                <option value="Networking">Networking</option>
                                <option value="Data Science">Data Science</option>
                                <option value="Web Development">Web Development</option>
                                <option value="Cybersecurity">Cybersecurity</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Topic *</label>
                            <input type="text" name="topic" class="form-control" required
                                   placeholder="e.g. Python Basics, SQL Joins, HTML Forms">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Questions</label>
                                <input type="number" name="question_count" class="form-control" value="5" min="3" max="10">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Difficulty</label>
                                <select name="difficulty" class="form-select">
                                    <option value="easy">Easy</option>
                                    <option value="medium" selected>Medium</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quiz Type</label>
                            <select name="quiz_type" class="form-select">
                                <option value="mcq">Multiple Choice</option>
                                <option value="short_answer">Short Answer</option>
                                <option value="mixed">Mixed (MCQ + Short Answer)</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="generateBtn">
                            <span class="spinner-border spinner-border-sm d-none" id="generateSpinner"></span>
                            Generate Quiz
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Show loading state on form submit
        document.getElementById('quizForm').addEventListener('submit', function() {
            const btn = document.getElementById('generateBtn');
            const spinner = document.getElementById('generateSpinner');
            btn.disabled = true;
            btn.textContent = ' Generating...';
            spinner.classList.remove('d-none');
            btn.prepend(spinner);
        });
    </script>
</body>
</html>
