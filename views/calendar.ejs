    <%- include('partial/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var calendarEl = document.getElementById('calendar');
            var createModal = new bootstrap.Modal(document.getElementById('createSessionModal'));
            var viewModal = new bootstrap.Modal(document.getElementById('viewEventModal'));
            
            // local cached events for instant filtering
            let cachedEvents = [];
            
            // Mini Calendar State
            let miniCalDate = new Date();
            let selectedDate = new Date();
            
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                editable: true,
                eventStartEditable: true,
                eventDurationEditable: true,
                selectable: true,
                events: function(fetchInfo, successCallback, failureCallback) {
                    if (cachedEvents.length > 0) {
                        successCallback(filterLocalEvents(cachedEvents));
                    } else {
                        fetch('/calendar/events')
                            .then(res => res.json())
                            .then(events => {
                                cachedEvents = events;
                                successCallback(filterLocalEvents(cachedEvents));
                            })
                            .catch(err => {
                                console.error("Error fetching calendar events:", err);
                                failureCallback(err);
                            });
                    }
                },
                
                // Click date to create study session
                select: function(info) {
                    // Set default dates
                    document.getElementById('sessionStart').value = info.startStr + "T09:00";
                    document.getElementById('sessionEnd').value = info.startStr + "T11:00";
                    document.getElementById('sessionTitle').value = "";
                    document.getElementById('sessionAllDay').checked = info.allDay || false;
                    
                    // Show modal
                    createModal.show();
                },
                
                // Click existing event to view details
                eventClick: function(info) {
                    var props = info.event.extendedProps;
                    var title = info.event.title;
                    
                    document.getElementById('eventTitle').innerText = title;
                    
                    var html = '';
                    var deleteBtn = document.getElementById('deleteSessionBtn');
                    var pomodoroBtn = document.getElementById('startPomodoroBtn');
                    deleteBtn.className = 'btn btn-danger px-4 py-2 d-none'; // default hide
                    pomodoroBtn.className = 'btn px-4 py-2 d-none'; // default hide
                    
                    if (props.type === 'assignment') {
                        html = `
                            <div class="d-flex flex-column gap-2">
                                <div><strong class="text-white">Module:</strong> ${props.module}</div>
                                <div><strong class="text-white">Priority:</strong> <span class="badge ${props.priority === 'high' ? 'bg-danger' : props.priority === 'medium' ? 'bg-warning text-dark' : 'bg-primary'}">${props.priority}</span></div>
                                <div><strong class="text-white">Status:</strong> <span class="badge bg-secondary">${props.status}</span></div>
                                <div><strong class="text-white">Deadline:</strong> ${new Date(info.event.start).toLocaleString()}</div>
                            </div>
                            <hr class="border-secondary">
                            <a href="/assignments" class="btn btn-sm btn-primary w-100 py-2 border-0" style="background-color: #6366f1; border-radius: 10px;">Go to Assignments Page</a>
                        `;
                    } else {
                        html = `
                            <div class="d-flex flex-column gap-2">
                                <div><strong class="text-white">Start:</strong> ${new Date(info.event.start).toLocaleString()}</div>
                                <div><strong class="text-white">End:</strong> ${new Date(info.event.end || info.event.start).toLocaleString()}</div>
                                <div><strong class="text-white">Status:</strong> <span class="badge bg-purple" style="background-color: #9b59b6;">${props.status || 'scheduled'}</span></div>
                            </div>
                        `;
                        // Allow delete for study sessions
                        deleteBtn.className = 'btn btn-danger px-4 py-2 d-block';
                        deleteBtn.onclick = function() {
                            if (confirm('Delete this study session?')) {
                                fetch(`/calendar/sessions/${props.dbId}/delete`, {
                                    method: 'POST'
                                })
                                .then(res => res.json())
                                .then(data => {
                                    if (data.success) {
                                        info.event.remove();
                                        cachedEvents = cachedEvents.filter(e => e.id !== `session-${props.dbId}`);
                                        viewModal.hide();
                                    }
                                });
                            }
                        };
                        // Show Start Studying (Pomodoro) button
                        pomodoroBtn.className = 'btn px-4 py-2 d-block';
                        pomodoroBtn.style = 'background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); color: #fff; border: none; border-radius: 20px; font-size: 0.85rem;';
                        pomodoroBtn.onclick = function() {
                            viewModal.hide();
                            startPomodoro(props.dbId, title.replace('📖 Study: ', ''));
                        };
                    }
                    
                    document.getElementById('eventDetailsContent').innerHTML = html;
                    viewModal.show();
                },
                
                // Synchronize mini calendar month view when main calendar navigation occurs
                datesSet: function(info) {
                    const activeDate = calendar.getDate();
                    selectedDate = activeDate;
                    miniCalDate = new Date(activeDate);
                    renderMiniCalendar();
                },

                // Only allow dragging study sessions, not assignment deadlines
                eventAllow: function(dropInfo, draggedEvent) {
                    return draggedEvent.extendedProps && draggedEvent.extendedProps.type === 'session';
                },

                // Handle drag & drop reschedule
                eventDrop: function(info) {
                    var props = info.event.extendedProps;
                    if (props.type !== 'session') {
                        info.revert();
                        return;
                    }
                    
                    var newStart = info.event.start.toISOString().slice(0, 19);
                    var newEnd = (info.event.end || info.event.start).toISOString().slice(0, 19);
                    
                    fetch(`/calendar/sessions/${props.dbId}/update`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ start_time: newStart, end_time: newEnd })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (!data.success) {
                            info.revert();
                            alert('Failed to reschedule session');
                        } else {
                            // Update cached events
                            cachedEvents = [];
                        }
                    })
                    .catch(() => info.revert());
                },

                // Handle resize (duration change)
                eventResize: function(info) {
                    var props = info.event.extendedProps;
                    if (props.type !== 'session') {
                        info.revert();
                        return;
                    }
                    
                    var newStart = info.event.start.toISOString().slice(0, 19);
                    var newEnd = info.event.end.toISOString().slice(0, 19);
                    
                    fetch(`/calendar/sessions/${props.dbId}/update`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ start_time: newStart, end_time: newEnd })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (!data.success) {
                            info.revert();
                            alert('Failed to update session duration');
                        } else {
                            cachedEvents = [];
                        }
                    })
                    .catch(() => info.revert());
                }
            });
            
            calendar.render();

            // ============================================
            // DYNAMIC EVENT FILTERING LOGIC
            // ============================================
            function filterLocalEvents(eventsList) {
                const searchKeyword = document.getElementById('searchEvent').value.toLowerCase();
                const filterAssignments = document.getElementById('filterAssignments').checked;
                const filterSessions = document.getElementById('filterSessions').checked;
                const filterExternal = document.getElementById('filterExternal').checked;
                
                return eventsList.filter(e => {
                    const titleMatches = e.title.toLowerCase().includes(searchKeyword);
                    
                    const type = e.extendedProps ? e.extendedProps.type : '';
                    let categoryMatches = true;
                    if (type === 'assignment') {
                        categoryMatches = filterAssignments;
                    } else if (type === 'session') {
                        categoryMatches = filterSessions;
                    } else {
                        // External integration sync event fallbacks (if any)
                        categoryMatches = filterExternal;
                    }
                    
                    return titleMatches && categoryMatches;
                });
            }

            function triggerRerender() {
                // This will trigger calendar.events callback with cached data
                calendar.refetchEvents();
            }

            // Input and checkbox listeners
            document.getElementById('searchEvent').addEventListener('input', triggerRerender);
            document.getElementById('filterAssignments').addEventListener('change', triggerRerender);
            document.getElementById('filterSessions').addEventListener('change', triggerRerender);
            document.getElementById('filterExternal').addEventListener('change', triggerRerender);

            // Add Calendar Alert Button Hook
            document.getElementById('btnAddCalendar').addEventListener('click', function() {
                alert("Study Buddy matches academic events automatically. You can toggle calendar layers in the checkboxes above, or connect Google/Outlook/iCloud calendars in the 'Sync Connections' drawer below.");
            });

            // ============================================
            // MINI MONTH CALENDAR COMPONENT
            // ============================================
            function renderMiniCalendar() {
                const year = miniCalDate.getFullYear();
                const month = miniCalDate.getMonth();
                
                const monthNames = [
                    "January", "February", "March", "April", "May", "June", 
                    "July", "August", "September", "October", "November", "December"
                ];
                document.getElementById('miniCalMonthYear').innerText = `${monthNames[month]} ${year}`;
                
                const gridEl = document.getElementById('miniCalendarGrid');
                gridEl.innerHTML = '';
                
                // Add weekdays (S M T W T F S)
                const weekdays = ["S", "M", "T", "W", "T", "F", "S"];
                weekdays.forEach(day => {
                    const cell = document.createElement('div');
                    cell.className = 'mini-cal-header-cell';
                    cell.innerText = day;
                    gridEl.appendChild(cell);
                });
                
                const firstDayIndex = new Date(year, month, 1).getDay();
                const totalDays = new Date(year, month + 1, 0).getDate();
                const prevTotalDays = new Date(year, month, 0).getDate();
                
                // Prev month padding days
                for (let i = firstDayIndex - 1; i >= 0; i--) {
                    const day = prevTotalDays - i;
                    const cell = document.createElement('div');
                    cell.className = 'mini-cal-day-cell prev-month';
                    cell.innerText = day;
                    cell.addEventListener('click', () => {
                        const targetDate = new Date(year, month - 1, day);
                        selectMiniCalDate(targetDate);
                    });
                    gridEl.appendChild(cell);
                }
                
                // Current month days
                for (let day = 1; day <= totalDays; day++) {
                    const cell = document.createElement('div');
                    cell.className = 'mini-cal-day-cell';
                    
                    const cellDate = new Date(year, month, day);
                    
                    // Highlight selected date
                    if (isSameDay(cellDate, selectedDate)) {
                        cell.classList.add('active');
                    }
                    
                    // Highlight today
                    if (isSameDay(cellDate, new Date())) {
                        cell.classList.add('today');
                    }
                    
                    cell.innerText = day;
                    cell.addEventListener('click', () => {
                        selectMiniCalDate(cellDate);
                    });
                    gridEl.appendChild(cell);
                }
                
                // Next month padding days to complete a 6-row layout grid (42 cells)
                const totalCellsUsed = firstDayIndex + totalDays;
                const remainingCells = 42 - totalCellsUsed;
                for (let day = 1; day <= remainingCells; day++) {
                    const cell = document.createElement('div');
                    cell.className = 'mini-cal-day-cell next-month';
                    cell.innerText = day;
                    cell.addEventListener('click', () => {
                        const targetDate = new Date(year, month + 1, day);
                        selectMiniCalDate(targetDate);
                    });
                    gridEl.appendChild(cell);
                }
            }
            
            function isSameDay(d1, d2) {
                return d1.getFullYear() === d2.getFullYear() &&
                       d1.getMonth() === d2.getMonth() &&
                       d1.getDate() === d2.getDate();
            }
            
            function selectMiniCalDate(date) {
                selectedDate = date;
                miniCalDate = new Date(date); // Center mini calendar month
                renderMiniCalendar();
                calendar.gotoDate(date); // Tell FullCalendar to shift view
            }
            
            document.getElementById('miniCalPrev').addEventListener('click', () => {
                miniCalDate.setMonth(miniCalDate.getMonth() - 1);
                renderMiniCalendar();
            });
            
            document.getElementById('miniCalNext').addEventListener('click', () => {
                miniCalDate.setMonth(miniCalDate.getMonth() + 1);
                renderMiniCalendar();
            });

            // Initial Draw of Mini Calendar
            renderMiniCalendar();
            
            // ============================================
            // SAVE STUDY SESSION HOOK
            // ============================================
            document.getElementById('saveSessionBtn').addEventListener('click', function() {
                var title = document.getElementById('sessionTitle').value;
                var start = document.getElementById('sessionStart').value;
                var end = document.getElementById('sessionEnd').value;
                
                if (!title || !start || !end) {
                    alert('Please fill out all fields.');
                    return;
                }
                
                fetch('/calendar/sessions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: title,
                        start_time: start,
                        end_time: end
                    })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // Clear cached events to force a fresh fetch from database
                        cachedEvents = [];
                        calendar.refetchEvents();
                        createModal.hide();
                    } else {
                        alert('Error saving session: ' + data.error);
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Connection error occurred.');
                });
            });

            // ============================================
            // AI CALENDAR ASSISTANT JS LOGIC
            // ============================================
            const aiChatToggle = document.getElementById('aiChatToggle');
            const aiChatWindow = document.getElementById('aiChatWindow');
            const aiChatClose = document.getElementById('aiChatClose');
            const aiChatSend = document.getElementById('aiChatSend');
            const aiChatInput = document.getElementById('aiChatInput');
            const aiChatMessages = document.getElementById('aiChatMessages');

            // Open/close widget
            aiChatToggle.addEventListener('click', function() {
                aiChatWindow.classList.toggle('show');
                if (aiChatWindow.classList.contains('show')) {
                    aiChatInput.focus();
                }
            });

            aiChatClose.addEventListener('click', function() {
                aiChatWindow.classList.remove('show');
            });

            // Global suggested query helper
            window.sendSuggestedQuery = function(queryText) {
                sendCalendarAIQuery(queryText);
            };

            // Send message triggers
            aiChatSend.addEventListener('click', function() {
                const text = aiChatInput.value.trim();
                if (text) {
                    sendCalendarAIQuery(text);
                    aiChatInput.value = '';
                }
            });

            aiChatInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const text = aiChatInput.value.trim();
                    if (text) {
                        sendCalendarAIQuery(text);
                        aiChatInput.value = '';
                    }
                }
            });

            function scrollToBottom() {
                aiChatMessages.scrollTop = aiChatMessages.scrollHeight;
            }

            function appendMessage(sender, text) {
                const bubble = document.createElement('div');
                bubble.className = `chat-bubble ${sender}`;
                bubble.innerText = text;
                aiChatMessages.appendChild(bubble);
                scrollToBottom();
                return bubble;
            }

            function sendCalendarAIQuery(queryText) {
                // 1. Add User bubble
                appendMessage('user', queryText);

                // 2. Add loading bubble
                const loadingBubble = appendMessage('assistant', 'Planning and matching schedule... Please wait.');

                // Get local time in ISO format (without timezone offset prefixing - we pass current time context)
                const currentLocalTime = new Date().toISOString().slice(0, 19);

                // 3. Post to AI backend
                fetch('/calendar/ai', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        query: queryText,
                        current_time: currentLocalTime
                    })
                })
                .then(res => res.json())
                .then(data => {
                    // Remove loading bubble
                    loadingBubble.remove();

                    if (data.success) {
                        // Append AI reply
                        appendMessage('assistant', data.reply);

                        // If events were added, refetch calendar data
                        if ((data.action === 'create_event' || data.action === 'daily_plan') && data.events && data.events.length > 0) {
                            cachedEvents = [];
                            calendar.refetchEvents();
                        }
                    } else {
                        appendMessage('assistant', 'Sorry, I encountered an issue processing your request. Please try again.');
                    }
                })
                .catch(err => {
                    console.error("AI Calendar request failed:", err);
                    loadingBubble.remove();
                    appendMessage('assistant', 'Connection error. Please make sure both servers are running.');
                });
            }

            // ============================================
            // POMODORO TIMER LOGIC
            // ============================================
            const FOCUS_DURATION = 25 * 60; // 25 minutes in seconds
            const BREAK_DURATION = 5 * 60;  // 5 minutes in seconds
            const TOTAL_POMODOROS = 4;
            const CIRCUMFERENCE = 2 * Math.PI * 90; // ~565.48

            let pomodoroState = {
                isRunning: false,
                isPaused: false,
                isBreak: false,
                timeRemaining: FOCUS_DURATION,
                totalTime: FOCUS_DURATION,
                currentPomodoro: 0,
                completedPomodoros: 0,
                sessionId: null,
                sessionTitle: '',
                interval: null,
                totalFocusSeconds: 0
            };

            function startPomodoro(sessionId, title) {
                pomodoroState.sessionId = sessionId;
                pomodoroState.sessionTitle = title;
                pomodoroState.currentPomodoro = 0;
                pomodoroState.completedPomodoros = 0;
                pomodoroState.isBreak = false;
                pomodoroState.isRunning = false;
                pomodoroState.isPaused = false;
                pomodoroState.timeRemaining = FOCUS_DURATION;
                pomodoroState.totalTime = FOCUS_DURATION;
                pomodoroState.totalFocusSeconds = 0;

                document.getElementById('pomodoroTitle').innerText = title;
                document.getElementById('pomodoroOverlay').classList.add('active');
                
                updatePomodoroDisplay();
                renderPomodoroPhases();
            }

            function updatePomodoroDisplay() {
                const mins = Math.floor(pomodoroState.timeRemaining / 60);
                const secs = pomodoroState.timeRemaining % 60;
                document.getElementById('pomodoroTime').innerText = 
                    `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
                
                // Update progress ring
                const progress = 1 - (pomodoroState.timeRemaining / pomodoroState.totalTime);
                const offset = CIRCUMFERENCE * (1 - progress);
                const progressEl = document.getElementById('pomodoroProgress');
                progressEl.style.strokeDashoffset = offset;
                progressEl.style.stroke = pomodoroState.isBreak ? '#f59e0b' : '#6366f1';

                // Update phase label
                document.getElementById('pomodoroPhaseLabel').innerText = 
                    pomodoroState.isBreak ? 'Break Time' : 'Focus';

                // Update stats
                document.getElementById('pomodoroStats').innerText = 
                    `${pomodoroState.completedPomodoros} pomodoro${pomodoroState.completedPomodoros !== 1 ? 's' : ''} completed`;
            }

            function renderPomodoroPhases() {
                const container = document.getElementById('pomodoroPhases');
                container.innerHTML = '';
                for (let i = 0; i < TOTAL_POMODOROS; i++) {
                    const dot = document.createElement('div');
                    dot.className = 'phase-dot';
                    if (i < pomodoroState.completedPomodoros) {
                        dot.classList.add('completed');
                    } else if (i === pomodoroState.currentPomodoro) {
                        dot.classList.add(pomodoroState.isBreak ? 'break' : 'active');
                    }
                    container.appendChild(dot);
                }
            }

            function pomodoroTick() {
                if (pomodoroState.timeRemaining <= 0) {
                    // Phase completed
                    if (!pomodoroState.isBreak) {
                        // Focus phase done
                        pomodoroState.completedPomodoros++;
                        pomodoroState.totalFocusSeconds += FOCUS_DURATION;
                        
                        // Play notification sound
                        try { new Audio('data:audio/wav;base64,UklGRl9vT19teleUFZRSBmbXQgAAAAEAAQABAAAAAAAAAAAAEAEABkYXRhQQBAAA==').play(); } catch(e) {}
                        
                        if (pomodoroState.completedPomodoros >= TOTAL_POMODOROS) {
                            // All pomodoros done!
                            endPomodoroSession(true);
                            return;
                        }
                        
                        // Start break
                        pomodoroState.isBreak = true;
                        pomodoroState.timeRemaining = BREAK_DURATION;
                        pomodoroState.totalTime = BREAK_DURATION;
                    } else {
                        // Break done, start next focus
                        pomodoroState.isBreak = false;
                        pomodoroState.currentPomodoro++;
                        pomodoroState.timeRemaining = FOCUS_DURATION;
                        pomodoroState.totalTime = FOCUS_DURATION;
                    }
                    renderPomodoroPhases();
                } else {
                    pomodoroState.timeRemaining--;
                    if (!pomodoroState.isBreak) {
                        pomodoroState.totalFocusSeconds++;
                    }
                }
                updatePomodoroDisplay();
            }

            function endPomodoroSession(completed) {
                clearInterval(pomodoroState.interval);
                pomodoroState.isRunning = false;
                pomodoroState.isPaused = false;
                
                const focusMinutes = Math.round(pomodoroState.totalFocusSeconds / 60);
                
                if (focusMinutes > 0) {
                    // Log to database
                    fetch('/calendar/pomodoro', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            session_id: pomodoroState.sessionId,
                            focus_minutes: focusMinutes
                        })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            // Refresh analytics & calendar
                            loadStudyAnalytics();
                            cachedEvents = [];
                            calendar.refetchEvents();
                        }
                    });
                }
                
                document.getElementById('pomodoroOverlay').classList.remove('active');
                
                if (completed) {
                    alert(`Great job! You completed ${pomodoroState.completedPomodoros} pomodoros (${focusMinutes} minutes of focus)!`);
                }
                
                // Reset button state
                const btn = document.getElementById('pomodoroStartPause');
                btn.innerHTML = '<i class="fa-solid fa-play me-1"></i>Start';
            }

            // Pomodoro button handlers
            document.getElementById('pomodoroStartPause').addEventListener('click', function() {
                if (!pomodoroState.isRunning) {
                    // Start
                    pomodoroState.isRunning = true;
                    pomodoroState.isPaused = false;
                    pomodoroState.interval = setInterval(pomodoroTick, 1000);
                    this.innerHTML = '<i class="fa-solid fa-pause me-1"></i>Pause';
                } else if (!pomodoroState.isPaused) {
                    // Pause
                    pomodoroState.isPaused = true;
                    clearInterval(pomodoroState.interval);
                    this.innerHTML = '<i class="fa-solid fa-play me-1"></i>Resume';
                } else {
                    // Resume
                    pomodoroState.isPaused = false;
                    pomodoroState.interval = setInterval(pomodoroTick, 1000);
                    this.innerHTML = '<i class="fa-solid fa-pause me-1"></i>Pause';
                }
            });

            document.getElementById('pomodoroReset').addEventListener('click', function() {
                clearInterval(pomodoroState.interval);
                pomodoroState.isRunning = false;
                pomodoroState.isPaused = false;
                pomodoroState.timeRemaining = pomodoroState.isBreak ? BREAK_DURATION : FOCUS_DURATION;
                pomodoroState.totalTime = pomodoroState.timeRemaining;
                updatePomodoroDisplay();
                document.getElementById('pomodoroStartPause').innerHTML = '<i class="fa-solid fa-play me-1"></i>Start';
            });

            document.getElementById('pomodoroStop').addEventListener('click', function() {
                if (confirm('End this study session? Your progress will be saved.')) {
                    endPomodoroSession(false);
                }
            });

            // ============================================
            // STUDY ANALYTICS LOADER
            // ============================================
            function loadStudyAnalytics() {
                fetch('/calendar/analytics')
                    .then(res => res.json())
                    .then(data => {
                        if (data.error) return;
                        
                        // Update stat cards
                        document.getElementById('statHours').innerText = data.thisWeek.totalHours;
                        document.getElementById('statSessions').innerText = data.thisWeek.sessions;
                        document.getElementById('statPomodoros').innerText = data.pomodoro.count;
                        document.getElementById('statFocus').innerText = data.pomodoro.focusMinutes;
                        
                        // Update comparison
                        const compEl = document.getElementById('statComparison');
                        if (data.comparison.direction === 'up') {
                            compEl.className = 'stat-comparison up';
                            compEl.innerHTML = `<i class="fa-solid fa-arrow-up me-1"></i>${data.comparison.diffHours}h more`;
                        } else if (data.comparison.direction === 'down') {
                            compEl.className = 'stat-comparison down';
                            compEl.innerHTML = `<i class="fa-solid fa-arrow-down me-1"></i>${data.comparison.diffHours}h less`;
                        } else {
                            compEl.className = 'stat-comparison same';
                            compEl.innerHTML = 'Same as last week';
                        }
                        
                        // Render heatmap
                        renderHeatmap(data.dailyBreakdown);
                    })
                    .catch(err => console.error('Analytics load failed:', err));
            }

            function renderHeatmap(dailyData) {
                const container = document.getElementById('heatmapRow');
                container.innerHTML = '';
                
                const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                const today = new Date();
                
                // Create cells for the last 7 days
                for (let i = 6; i >= 0; i--) {
                    const date = new Date(today);
                    date.setDate(date.getDate() - i);
                    const dateStr = date.toISOString().slice(0, 10);
                    
                    // Find matching data
                    const dayData = dailyData.find(d => {
                        const dStr = new Date(d.study_date).toISOString().slice(0, 10);
                        return dStr === dateStr;
                    });
                    
                    const minutes = dayData ? dayData.minutes : 0;
                    
                    // Determine intensity level
                    let level = '';
                    if (minutes > 0 && minutes <= 30) level = 'level-1';
                    else if (minutes > 30 && minutes <= 60) level = 'level-2';
                    else if (minutes > 60 && minutes <= 120) level = 'level-3';
                    else if (minutes > 120) level = 'level-4';
                    
                    const cell = document.createElement('div');
                    cell.className = `heatmap-cell ${level}`;
                    cell.innerHTML = `
                        <span class="day-label">${dayNames[date.getDay()]}</span>
                        <span>${minutes > 0 ? minutes + 'm' : '-'}</span>
                    `;
                    cell.title = `${dateStr}: ${minutes} minutes`;
                    container.appendChild(cell);
                }
            }

            // Load analytics on page load
            loadStudyAnalytics();
        });
    </script>
</body>
</html>
