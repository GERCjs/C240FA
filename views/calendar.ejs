<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Study Calendar - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- FullCalendar CDN -->
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif !important;
            background-color: #121214 !important;
        }
        
        .page-container {
            background-color: #121214;
        }

        /* Sidebar Glassmorphic Style */
        .sidebar-container {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 20px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            height: 100%;
        }

        .calendar-container {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 24px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            position: relative;
        }

        /* Fix drag mirror positioning */
        .fc-event-mirror {
            position: fixed !important;
            z-index: 9999 !important;
        }

        /* Search input decoration */
        .search-wrapper {
            position: relative;
        }
        
        .search-wrapper i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.4);
            font-size: 0.9rem;
        }

        .search-input {
            background-color: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            border-radius: 20px;
            padding-left: 36px;
            color: #fff !important;
            font-size: 0.9rem;
            height: 38px;
            transition: all 0.2s ease;
        }

        .search-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .search-input:focus {
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25) !important;
            border-color: #6366f1 !important;
            background-color: rgba(255, 255, 255, 0.08) !important;
        }

        /* Mini Monthly Calendar Picker */
        .mini-calendar {
            background: rgba(255, 255, 255, 0.01);
            border-radius: 12px;
            padding: 10px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        .mini-calendar-header {
            font-size: 0.85rem;
            font-weight: 600;
            color: #fff;
        }

        .mini-calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 2px;
            text-align: center;
            margin-top: 10px;
        }

        .mini-cal-header-cell {
            font-size: 0.7rem;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.4);
            padding: 4px 0;
            text-transform: uppercase;
        }

        .mini-cal-day-cell {
            font-size: 0.8rem;
            padding: 6px 0;
            cursor: pointer;
            border-radius: 50%;
            color: rgba(255, 255, 255, 0.85);
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s ease;
        }

        .mini-cal-day-cell:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .mini-cal-day-cell.prev-month, 
        .mini-cal-day-cell.next-month {
            color: rgba(255, 255, 255, 0.25);
        }

        .mini-cal-day-cell.active {
            background: #6366f1 !important;
            color: #fff !important;
            font-weight: bold;
        }

        .mini-cal-day-cell.today:not(.active) {
            border: 1px solid #6366f1;
            color: #6366f1;
            font-weight: bold;
        }

        /* Checkbox filter styling */
        .color-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 8px;
        }

        .bg-danger-dot { background-color: #e74c3c; }
        .bg-purple-dot { background-color: #9b59b6; }
        .bg-info-dot { background-color: #3498db; }

        .form-check {
            padding-left: 0;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
        }

        .form-check-input {
            float: right;
            margin-left: auto;
            margin-right: 0;
            width: 16px;
            height: 16px;
            cursor: pointer;
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .form-check-input:checked {
            background-color: #6366f1;
            border-color: #6366f1;
        }

        .form-check-label {
            display: flex;
            align-items: center;
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.9rem;
            cursor: pointer;
            flex-grow: 1;
        }

        /* Settings Collapse Styling */
        .accordion-button::after {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23fff'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e") !important;
        }

        .sync-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 10px;
            transition: all 0.2s ease;
        }

        .sync-card:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, 0.04);
        }

        .sync-icon {
            font-size: 1.3em;
            margin-right: 10px;
        }
        
        .sync-google { color: #ea4335; }
        .sync-outlook { color: #0078d4; }
        .sync-apple { color: #f5f5f7; }

        /* FullCalendar Customizations */
        .fc {
            color: #fff !important;
        }
        
        .fc-theme-standard td, 
        .fc-theme-standard th {
            border: 1px solid rgba(255, 255, 255, 0.06) !important;
        }

        .fc-theme-standard .fc-scrollgrid {
            border: 1px solid rgba(255, 255, 255, 0.06) !important;
            border-radius: 12px;
            overflow: hidden;
        }

        .fc .fc-toolbar-title {
            color: #fff;
            font-weight: 700;
            font-size: 1.4rem;
        }

        .fc .fc-button-primary {
            background-color: rgba(255, 255, 255, 0.05) !important;
            border-color: rgba(255, 255, 255, 0.08) !important;
            color: #fff !important;
            transition: all 0.2s ease;
            text-transform: capitalize;
            font-size: 0.85rem !important;
        }

        .fc .fc-button-primary:hover {
            background-color: rgba(255, 255, 255, 0.1) !important;
            border-color: rgba(255, 255, 255, 0.12) !important;
        }

        .fc .fc-button-active {
            background-color: #6366f1 !important;
            border-color: #6366f1 !important;
        }

        .fc-day-today {
            background: rgba(99, 102, 241, 0.08) !important;
        }

        .fc-event {
            cursor: pointer;
            border-radius: 6px !important;
            padding: 3px 6px !important;
            font-size: 0.82rem !important;
            font-weight: 500;
            border: none !important;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.15) !important;
            transition: transform 0.1s ease;
        }

        .fc-event:hover {
            transform: scale(1.02);
        }

        /* Modal styling variables & aesthetics */
        .modal-content {
            background-color: #18181c !important;
            color: #fff !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
        }
        
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25) !important;
            border-color: #6366f1 !important;
        }

        /* AI Chat Widget Styles */
        .ai-chat-toggle {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            color: #fff;
            border: none;
            box-shadow: 0 8px 32px rgba(99, 102, 241, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 1050;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .ai-chat-toggle:hover {
            transform: scale(1.1) rotate(15deg);
            box-shadow: 0 12px 40px rgba(99, 102, 241, 0.6);
        }

        .ai-chat-window {
            position: fixed;
            bottom: 105px;
            right: 30px;
            width: 380px;
            height: 520px;
            background: rgba(24, 24, 28, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            opacity: 0;
            transform: translateY(20px) scale(0.95);
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .ai-chat-window.show {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: auto;
        }

        .ai-chat-header {
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .ai-chat-messages {
            flex-grow: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .chat-bubble {
            max-width: 80%;
            padding: 12px 16px;
            border-radius: 16px;
            font-size: 0.88rem;
            line-height: 1.4;
        }

        .chat-bubble.assistant {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.9);
            align-self: flex-start;
            border-bottom-left-radius: 4px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .chat-bubble.user {
            background: #6366f1;
            color: #fff;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .ai-chat-input-area {
            padding: 15px 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(24, 24, 28, 0.98);
        }

        .ai-suggested-chips {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 10px;
            margin-bottom: 5px;
        }

        .ai-suggested-chips::-webkit-scrollbar {
            height: 4px;
        }

        .ai-suggested-chips::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .ai-chip {
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.2);
            color: #a5b4fc;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s ease;
        }

        .ai-chip:hover {
            background: rgba(99, 102, 241, 0.2);
            transform: translateY(-1px);
        }

        /* Study Analytics Styles */
        .analytics-panel {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 16px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 12px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.2s ease;
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-1px);
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .stat-label {
            font-size: 0.7rem;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 4px;
        }

        .stat-comparison {
            font-size: 0.72rem;
            margin-top: 4px;
        }

        .stat-comparison.up { color: #22c55e; }
        .stat-comparison.down { color: #ef4444; }
        .stat-comparison.same { color: rgba(255, 255, 255, 0.4); }

        /* Heatmap */
        .heatmap-row {
            display: flex;
            gap: 4px;
            margin-top: 10px;
        }

        .heatmap-cell {
            flex: 1;
            aspect-ratio: 1;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.04);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.5);
            transition: all 0.2s ease;
            cursor: default;
            position: relative;
        }

        .heatmap-cell .day-label {
            font-size: 0.6rem;
            margin-bottom: 2px;
            font-weight: 600;
        }

        .heatmap-cell.level-1 { background: rgba(99, 102, 241, 0.15); }
        .heatmap-cell.level-2 { background: rgba(99, 102, 241, 0.3); }
        .heatmap-cell.level-3 { background: rgba(99, 102, 241, 0.5); }
        .heatmap-cell.level-4 { background: rgba(99, 102, 241, 0.7); color: #fff; }

        /* Pomodoro Timer Styles */
        .pomodoro-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s ease;
        }

        .pomodoro-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .pomodoro-card {
            background: #18181c;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 40px;
            text-align: center;
            width: 380px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .pomodoro-timer-ring {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            margin: 20px auto;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pomodoro-timer-ring svg {
            position: absolute;
            top: 0;
            left: 0;
            transform: rotate(-90deg);
        }

        .pomodoro-timer-ring .timer-text {
            font-size: 2.8rem;
            font-weight: 700;
            color: #fff;
            z-index: 1;
        }

        .pomodoro-timer-ring .timer-label {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.5);
            z-index: 1;
        }

        .pomodoro-session-title {
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 20px;
        }

        .pomodoro-controls {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 24px;
        }

        .pomodoro-btn {
            padding: 10px 24px;
            border-radius: 20px;
            border: none;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .pomodoro-btn.primary {
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            color: #fff;
        }

        .pomodoro-btn.primary:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
        }

        .pomodoro-btn.secondary {
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
        }

        .pomodoro-btn.secondary:hover {
            background: rgba(255, 255, 255, 0.12);
        }

        .pomodoro-btn.danger {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        .pomodoro-btn.danger:hover {
            background: rgba(239, 68, 68, 0.25);
        }

        .pomodoro-phase {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin-bottom: 16px;
        }

        .phase-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
        }

        .phase-dot.completed { background: #22c55e; }
        .phase-dot.active { background: #6366f1; box-shadow: 0 0 10px rgba(99, 102, 241, 0.5); }
        .phase-dot.break { background: #f59e0b; }

        /* Drag feedback */
        .fc-event.fc-event-dragging {
            opacity: 0.7;
            box-shadow: 0 8px 24px rgba(99, 102, 241, 0.4) !important;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 text-white page-container">
    <%- include('partial/navbar') %>

    <div class="container-fluid py-4 flex-grow-1 px-lg-5">
        <div class="row g-4">
            <!-- Sidebar: Search, Mini Calendar, Filters & Sync Config -->
            <div class="col-lg-3">
                <div class="sidebar-container d-flex flex-column gap-4">
                    <!-- Title -->
                    <div>
                        <h4 class="mb-1 text-white font-weight-bold"><i class="fa-solid fa-calendar-days text-indigo me-2" style="color: #6366f1;"></i>Calendar</h4>
                        <p class="text-secondary small mb-0">Organize and sync your academic schedule.</p>
                    </div>

                    <!-- Search Box -->
                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="searchEvent" class="form-control search-input" placeholder="Search event...">
                    </div>

                    <!-- Mini Calendar -->
                    <div class="mini-calendar">
                        <div class="d-flex justify-content-between align-items-center mb-1 px-1">
                            <span class="mini-calendar-header" id="miniCalMonthYear">August 2025</span>
                            <div>
                                <button type="button" class="btn btn-sm btn-link text-white-50 p-1 border-0" id="miniCalPrev"><i class="fa-solid fa-chevron-left" style="font-size: 0.8rem;"></i></button>
                                <button type="button" class="btn btn-sm btn-link text-white-50 p-1 border-0" id="miniCalNext"><i class="fa-solid fa-chevron-right" style="font-size: 0.8rem;"></i></button>
                            </div>
                        </div>
                        <div class="mini-calendar-grid" id="miniCalendarGrid">
                            <!-- Populated dynamically via JS -->
                        </div>
                    </div>

                    <!-- My Calendars Checklist -->
                    <div>
                        <h6 class="mb-3 text-white font-weight-bold small text-uppercase tracking-wider opacity-75">My calendars</h6>
                        
                        <div class="form-check">
                            <label class="form-check-label" for="filterAssignments">
                                <span class="color-dot bg-danger-dot"></span>Assignments (DL)
                            </label>
                            <input class="form-check-input" type="checkbox" id="filterAssignments" checked>
                        </div>
                        
                        <div class="form-check">
                            <label class="form-check-label" for="filterSessions">
                                <span class="color-dot bg-purple-dot"></span>Study Sessions
                            </label>
                            <input class="form-check-input" type="checkbox" id="filterSessions" checked>
                        </div>

                        <div class="form-check mb-3">
                            <label class="form-check-label" for="filterExternal">
                                <span class="color-dot bg-info-dot"></span>External Sync
                            </label>
                            <input class="form-check-input" type="checkbox" id="filterExternal" checked>
                        </div>

                        <button class="btn btn-sm btn-outline-light w-100 py-2 border-opacity-25" id="btnAddCalendar" style="border-radius: 10px; font-size: 0.85rem;"><i class="fa-solid fa-plus me-1"></i> Add Calendar</button>
                    </div>

                    <!-- Study Analytics Panel -->
                    <div class="analytics-panel">
                        <h6 class="mb-3 text-white small text-uppercase tracking-wider opacity-75">
                            <i class="fa-solid fa-chart-simple me-1" style="color: #6366f1;"></i>This Week
                        </h6>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="stat-card">
                                    <div class="stat-value" id="statHours">-</div>
                                    <div class="stat-label">Hours Studied</div>
                                    <div class="stat-comparison same" id="statComparison">-</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <div class="stat-value" id="statSessions">-</div>
                                    <div class="stat-label">Sessions</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <div class="stat-value" id="statPomodoros">-</div>
                                    <div class="stat-label">Pomodoros</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-card">
                                    <div class="stat-value" id="statFocus">-</div>
                                    <div class="stat-label">Focus Mins</div>
                                </div>
                            </div>
                        </div>
                        <div class="small text-white-50 mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Last 7 Days Activity</div>
                        <div class="heatmap-row" id="heatmapRow">
                            <!-- Filled dynamically -->
                        </div>
                    </div>

                    <!-- External Sync settings in accordion drawer -->
                    <div class="accordion accordion-flush" id="syncAccordion">
                        <div class="accordion-item bg-transparent border-0">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed bg-transparent text-white border-0 px-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSync" aria-expanded="false" style="font-size: 0.9rem; font-weight: 600;">
                                    <i class="fa-solid fa-cloud-arrow-up me-2 text-white-50"></i> Sync Connections
                                </button>
                            </h2>
                            <div id="collapseSync" class="accordion-collapse collapse" data-bs-parent="#syncAccordion">
                                <div class="accordion-body px-0 py-2">
                                    <!-- Google Calendar -->
                                    <div class="sync-card d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="fa-brands fa-google sync-icon sync-google"></i>
                                            <div>
                                                <h6 class="mb-0 text-white" style="font-size: 0.85rem;">Google</h6>
                                                <small class="text-secondary" style="font-size: 0.75rem;">
                                                    <%= connections.google ? 'Connected' : 'Not Connected' %>
                                                </small>
                                            </div>
                                        </div>
                                        <% if (connections.google) { %>
                                            <form action="/calendar/disconnect/google" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-xs btn-outline-danger py-0 px-2" style="font-size: 0.7rem;">Disconnect</button>
                                            </form>
                                        <% } else { %>
                                            <a href="/auth/google" class="btn btn-xs btn-primary py-0 px-2" style="font-size: 0.7rem; background-color: #6366f1; border: none;">Connect</a>
                                        <% } %>
                                    </div>

                                    <!-- Apple Calendar -->
                                    <div class="sync-card d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center">
                                            <i class="fa-brands fa-apple sync-icon sync-apple"></i>
                                            <div>
                                                <h6 class="mb-0 text-white" style="font-size: 0.85rem;">iCloud</h6>
                                                <small class="text-secondary" style="font-size: 0.75rem;">
                                                    <%= connections.apple ? 'Connected' : 'Not Connected' %>
                                                </small>
                                            </div>
                                        </div>
                                        <% if (connections.apple) { %>
                                            <form action="/calendar/disconnect/apple" method="POST" class="m-0">
                                                <button type="submit" class="btn btn-xs btn-outline-danger py-0 px-2" style="font-size: 0.7rem;">Disconnect</button>
                                            </form>
                                        <% } else { %>
                                            <button class="btn btn-xs btn-primary py-0 px-2" style="font-size: 0.7rem; background-color: #6366f1; border: none;" data-bs-toggle="modal" data-bs-target="#appleConnectModal">Connect</button>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Calendar Grid Area -->
