<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz History - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <h2>📊 Results: <%= quizTitle %></h2>

        <table class="table table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Score</th>
                    <th>Percentage</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <% attempts.forEach((a, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td><%= a.score %>/<%= a.total %></td>
                        <td>
                            <span class="badge bg-<%= a.percentage >= 70 ? 'success' : a.percentage >= 50 ? 'warning' : 'danger' %>">
                                <%= a.percentage %>%
                            </span>
                        </td>
                        <td><%= new Date(a.completed_at).toLocaleString() %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <a href="/quizzes" class="btn btn-secondary">← Back to Quizzes</a>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
