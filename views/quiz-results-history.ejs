<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz History - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>📊 Quiz History</h2>
                <p class="text-muted mb-0"><%= quizTitle %></p>
            </div>
            <% if (typeof quizId !== 'undefined') { %>
                <a href="/quizzes/<%= quizId %>" class="btn btn-primary">🔄 Retake Quiz</a>
            <% } %>
        </div>

        <!-- Performance Summary -->
        <% if (attempts.length > 0) { %>
            <div class="row g-3 mb-4">
                <div class="col-md-3 col-6">
                    <div class="card text-center bg-light">
                        <div class="card-body">
                            <h4 class="text-primary"><%= attempts.length %></h4>
                            <small class="text-muted">Total Attempts</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card text-center bg-light">
                        <div class="card-body">
                            <% const best = Math.max(...attempts.map(a => parseFloat(a.percentage))); %>
                            <h4 class="text-success"><%= best %>%</h4>
                            <small class="text-muted">Best Score</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card text-center bg-light">
                        <div class="card-body">
                            <% const avg = Math.round(attempts.reduce((s, a) => s + parseFloat(a.percentage), 0) / attempts.length); %>
                            <h4 class="text-info"><%= avg %>%</h4>
                            <small class="text-muted">Average</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card text-center bg-light">
                        <div class="card-body">
                            <% const latest = parseFloat(attempts[0].percentage); %>
                            <h4 class="<%= latest >= 70 ? 'text-success' : latest >= 50 ? 'text-warning' : 'text-danger' %>"><%= latest %>%</h4>
                            <small class="text-muted">Latest Score</small>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Attempts Table -->
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Score</th>
                            <th>Percentage</th>
                            <th>Date</th>
                            <th>Trend</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% attempts.forEach((a, i) => { %>
                            <tr>
                                <td><%= i + 1 %></td>
                                <td><%= a.score %>/<%= a.total %></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 8px; max-width: 100px;">
                                            <div class="progress-bar bg-<%= a.percentage >= 70 ? 'success' : a.percentage >= 50 ? 'warning' : 'danger' %>"
                                                 style="width: <%= a.percentage %>%"></div>
                                        </div>
                                        <span class="badge bg-<%= a.percentage >= 70 ? 'success' : a.percentage >= 50 ? 'warning' : 'danger' %>">
                                            <%= a.percentage %>%
                                        </span>
                                    </div>
                                </td>
                                <td><%= new Date(a.completed_at).toLocaleString() %></td>
                                <td>
                                    <% if (i < attempts.length - 1) { %>
                                        <% const prev = parseFloat(attempts[i + 1].percentage); const curr = parseFloat(a.percentage); %>
                                        <% if (curr > prev) { %>
                                            <span class="text-success">↑ +<%= Math.round(curr - prev) %>%</span>
                                        <% } else if (curr < prev) { %>
                                            <span class="text-danger">↓ <%= Math.round(curr - prev) %>%</span>
                                        <% } else { %>
                                            <span class="text-muted">→ same</span>
                                        <% } %>
                                    <% } else { %>
                                        <span class="text-muted">—</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4">
            <a href="/quizzes" class="btn btn-secondary">← Back to Quizzes</a>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
