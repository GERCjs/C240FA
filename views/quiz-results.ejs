<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Results - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <div class="container py-4 flex-grow-1">
        <div class="text-center mb-4">
            <div class="display-1 text-{{ score_badge(percentage) }}">{{ percentage }}%</div>
            <p class="lead">You scored {{ score }} out of {{ total }}</p>
        </div>

        {% for g in graded %}
            <div class="card mb-3 border-{{ 'success' if g.is_correct else 'danger' }}">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h6>Question {{ loop.index }}</h6>
                        <span class="badge bg-{{ 'success' if g.is_correct else 'danger' }}">
                            {{ 'Correct' if g.is_correct else 'Incorrect' }}
                        </span>
                    </div>
                    <p>{{ g.question }}</p>
                    <p><strong>Your answer:</strong> {{ g.user_answer or '(No answer)' }}</p>
                    {% if not g.is_correct %}
                        <p class="text-success"><strong>Correct answer:</strong> {{ g.correct_answer }}</p>
                    {% endif %}
                    {% if g.explanation %}
                        <div class="alert alert-info">
                            <strong>Explanation:</strong> {{ g.explanation }}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}

        <div class="text-center">
            <a href="/quizzes/{{ quiz.id if quiz is defined else '' }}" class="btn btn-primary">Retake Quiz</a>
            <a href="/quizzes" class="btn btn-secondary">Back to Quizzes</a>
        </div>
    </div>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
