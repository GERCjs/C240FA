<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Results - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="text-center mb-4">
            <h2>Quiz Results</h2>
            <div class="display-1 <%= percentage >= 70 ? 'text-success' : percentage >= 50 ? 'text-warning' : 'text-danger' %>">
                <%= percentage %>%
            </div>
            <p class="lead">You scored <%= score %> out of <%= total %></p>
        </div>

        <!-- Detailed Results -->
        <% graded.forEach((g, index) => { %>
            <div class="card mb-3 border-<%= g.is_correct ? 'success' : 'danger' %>">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h6>Question <%= index + 1 %></h6>
                        <span class="badge bg-<%= g.is_correct ? 'success' : 'danger' %>">
                            <%= g.is_correct ? '✓ Correct' : '✗ Incorrect' %>
                        </span>
                    </div>
                    <p><%= g.question %></p>
                    <p><strong>Your answer:</strong> <%= g.user_answer || '(No answer)' %></p>
                    <% if (!g.is_correct) { %>
                        <p class="text-success"><strong>Correct answer:</strong> <%= g.correct_answer %></p>
                    <% } %>
                    <% if (g.explanation) { %>
                        <div class="alert alert-info mt-2 mb-0">
                            <strong>Explanation:</strong> <%= g.explanation %>
                        </div>
                    <% } %>
                </div>
            </div>
        <% }) %>

        <div class="d-flex justify-content-between mt-4">
            <a href="/quizzes" class="btn btn-secondary">← Back to Quizzes</a>
            <a href="/quizzes/<%= typeof quiz !== 'undefined' ? quiz.id : '' %>" class="btn btn-primary">Retake Quiz</a>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
