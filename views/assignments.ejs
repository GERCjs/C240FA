<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Assignments - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>📅 Assignment Planner</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">+ New Assignment</button>
        </div>

        <% if (typeof overdue !== 'undefined' && overdue.length > 0) { %>
            <div class="alert alert-danger">
                <strong>⚠️ Overdue:</strong> You have <%= overdue.length %> overdue assignment(s)!
            </div>
        <% } %>

        <!-- Upcoming -->
        <h4 class="mt-4">📌 Upcoming</h4>
        <% if (typeof upcoming !== 'undefined' && upcoming.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Module</th>
                            <th>Deadline</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% upcoming.forEach(a => { %>
                            <tr>
                                <td><strong><%= a.title %></strong></td>
                                <td><%= a.module %></td>
                                <td><%= new Date(a.deadline).toLocaleDateString() %></td>
                                <td>
                                    <span class="badge bg-<%= a.priority === 'high' ? 'danger' : a.priority === 'medium' ? 'warning' : 'secondary' %>">
                                        <%= a.priority %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-<%= a.status === 'in_progress' ? 'primary' : 'secondary' %>">
                                        <%= a.status %>
                                    </span>
                                </td>
                                <td>
                                    <form action="/assignments/<%= a.id %>/update" method="POST" class="d-inline">
                                        <input type="hidden" name="status" value="in_progress">
                                        <button class="btn btn-sm btn-outline-primary" title="Start">▶️</button>
                                    </form>
                                    <form action="/assignments/<%= a.id %>/update" method="POST" class="d-inline">
                                        <input type="hidden" name="status" value="completed">
                                        <button class="btn btn-sm btn-outline-success" title="Complete">✅</button>
                                    </form>
                                    <form action="/assignments/<%= a.id %>/plan" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-outline-info" title="Generate Study Plan">📋</button>
                                    </form>
                                    <form action="/assignments/<%= a.id %>/delete" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                            <% if (a.study_plan) { %>
                                <tr>
                                    <td colspan="6">
                                        <div class="alert alert-info mb-0">
                                            <strong>📋 Study Plan:</strong><br>
                                            <pre class="mb-0" style="white-space: pre-wrap;"><%= a.study_plan %></pre>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center text-muted py-4">
                <p>No upcoming assignments. Create one to get started!</p>
            </div>
        <% } %>

        <!-- Overdue -->
        <% if (typeof overdue !== 'undefined' && overdue.length > 0) { %>
            <h4 class="mt-4 text-danger">⚠️ Overdue</h4>
            <div class="table-responsive">
                <table class="table table-hover table-danger">
                    <thead>
                        <tr><th>Title</th><th>Module</th><th>Deadline</th><th>Priority</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        <% overdue.forEach(a => { %>
                            <tr>
                                <td><%= a.title %></td>
                                <td><%= a.module %></td>
                                <td><%= new Date(a.deadline).toLocaleDateString() %></td>
                                <td><span class="badge bg-danger"><%= a.priority %></span></td>
                                <td>
                                    <form action="/assignments/<%= a.id %>/update" method="POST" class="d-inline">
                                        <input type="hidden" name="status" value="completed">
                                        <button class="btn btn-sm btn-success">Mark Done</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>

        <!-- Completed -->
        <% if (typeof completed !== 'undefined' && completed.length > 0) { %>
            <h4 class="mt-4 text-success">✅ Completed</h4>
            <ul class="list-group">
                <% completed.forEach(a => { %>
                    <li class="list-group-item d-flex justify-content-between">
                        <span><s><%= a.title %></s> - <%= a.module %></span>
                        <small class="text-muted"><%= new Date(a.deadline).toLocaleDateString() %></small>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </div>

    <!-- Add Assignment Modal -->
    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/assignments" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">New Assignment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <input type="text" name="title" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Module</label>
                            <input type="text" name="module" class="form-control" required placeholder="e.g. C240 Programming">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Deadline</label>
                            <input type="datetime-local" name="deadline" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <select name="priority" class="form-select">
                                <option value="low">Low</option>
                                <option value="medium" selected>Medium</option>
                                <option value="high">High</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
