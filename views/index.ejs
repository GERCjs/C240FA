<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        AI Learning Assistant
    </title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

    <div class="container">

        <a class="navbar-brand" href="/">
            AI Learning Assistant
        </a>

        <div>

            <a
                href="/register"
                class="btn btn-outline-light me-2">

                Register

            </a>

            <a
                href="/login"
                class="btn btn-warning">

                Login

            </a>

        </div>

    </div>

</nav>

<section class="py-5 bg-light">

    <div class="container text-center">

        <h1 class="display-4 fw-bold">

            AI Learning Assistant

        </h1>

        <p class="lead">

            Learn smarter using
            Retrieval-Augmented Generation (RAG)

        </p>

        <p>

            Ask questions about
            Programming,
            Databases,
            AI Prompting,
            and more.

        </p>

        <a
            href="/register"
            class="btn btn-primary btn-lg mt-3">

            Get Started

        </a>

    </div>

</section>

<section class="container py-5">

    <div class="row">

        <div class="col-md-4">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h4>
                        Knowledge Base
                    </h4>

                    <p>

                        Retrieve learning materials
                        from your curated knowledge base.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h4>
                        AI Responses
                    </h4>

                    <p>

                        Generate beginner-friendly
                        answers using Gemini 2.5 Flash.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h4>
                        Chat History
                    </h4>

                    <p>

                        Store conversations
                        for future learning.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<footer
    class="bg-dark text-white text-center py-3">

    <p>

        © 2026 AI Learning Assistant

    </p>

</footer>

</body>

</html>