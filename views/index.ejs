<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Buddy AI - Learning Assistant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <section class="py-5 bg-light">
        <div class="container text-center">
            <h1 class="display-4 fw-bold">Study Buddy AI</h1>
            <p class="lead">Learn smarter using Retrieval-Augmented Generation (RAG)</p>
            <p>Ask questions about Programming, Databases, AI Prompting, and more.</p>
            <a href="/register" class="btn btn-primary btn-lg mt-3">Get Started</a>
        </div>
    </section>

    <section class="container py-5">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>AI Chatbot</h4>
                        <p>Ask questions and get beginner-friendly explanations powered by RAG.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>Quiz Generator</h4>
                        <p>Generate MCQs and short-answer questions from your study materials.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>Assignment Planner</h4>
                        <p>Track deadlines and get AI-generated study plans.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>Document Upload</h4>
                        <p>Upload PDFs and notes for the AI to reference in answers.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>Study Summaries</h4>
                        <p>Auto-generate concise revision notes and flashcards.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4>Academic FAQ</h4>
                        <p>Get answers about GPA, attendance, exams, and policies.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
