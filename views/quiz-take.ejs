<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= quiz.title %> - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .timer-bar {
            background: #FFFFFF;
            border: 1px solid #D8E9FF;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(60, 100, 180, 0.08);
            color: #1F2937;
            padding: 18px 20px;
            overflow: hidden;
        }
        .quiz-status-panel {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 220px;
            gap: 20px;
            align-items: center;
        }
        .quiz-title {
            color: #1F2937;
            font-size: clamp(1.35rem, 2.2vw, 1.8rem);
            font-weight: 700;
            letter-spacing: 0;
            line-height: 1.2;
        }
        .quiz-meta {
            color: #64748B;
            font-size: 0.9rem;
            margin-top: 4px;
        }
        .progress-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 16px;
        }
        .progress-label {
            color: #64748B;
            flex: 0 0 auto;
            font-size: 0.82rem;
            font-weight: 600;
            white-space: nowrap;
        }
        .timer-bar .progress {
            background-color: #EAF4FF;
            border-radius: 999px;
            flex: 1 1 auto;
            height: 8px;
            overflow: hidden;
        }
        .timer-bar .progress-bar {
            background: linear-gradient(90deg, #4A90FF, #6CB8FF);
            border-radius: inherit;
            box-shadow: 0 0 14px rgba(74, 144, 255, 0.28);
        }
        .timer-card {
            background: #FFFFFF;
            border: 1px solid #B8D8FF;
            border-radius: 14px;
            box-shadow: 0 8px 24px rgba(60, 100, 180, 0.08);
            padding: 14px 16px;
            text-align: center;
        }
        .timer-icon {
            align-items: center;
            background: #EAF4FF;
            border: 1px solid #D8E9FF;
            border-radius: 50%;
            color: #4A90FF;
            display: inline-flex;
            font-size: 0.95rem;
            height: 30px;
            justify-content: center;
            margin-bottom: 6px;
            width: 30px;
        }
        .timer-heading {
            color: #64748B;
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            margin-bottom: 4px;
        }
        #timer {
            color: #1F2937;
            font-weight: 800;
        }
        #timerDisplay {
            display: block;
            font-size: clamp(1.8rem, 4vw, 2.35rem);
            line-height: 1;
        }
        .timer-warning { color: #EF5350; font-weight: 800; }
        .question-card {
            padding: 0.35rem;
            transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
        }
        .question-card.answered { border-left: 4px solid #43C47A; }
        .progress-tracker {
            color: #64748B;
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            margin-top: 6px;
        }
        @media (max-width: 992px) {
            .quiz-status-panel {
                grid-template-columns: minmax(0, 1fr) 190px;
                gap: 16px;
            }
            .timer-card {
                padding: 12px 14px;
            }
            #timerDisplay {
                font-size: 1.9rem;
            }
        }
        @media (max-width: 768px) {
            .timer-bar {
                padding: 16px;
            }
            .quiz-status-panel {
                grid-template-columns: 1fr;
                gap: 14px;
            }
            .progress-row {
                gap: 10px;
                margin-top: 14px;
            }
            .progress-label {
                align-self: flex-end;
            }
            .timer-card {
                justify-self: stretch;
                padding: 12px 14px;
            }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <!-- Timer & Progress Bar -->
        <div class="timer-bar mb-4">
            <div class="quiz-status-panel">
                <div class="quiz-info">
                    <h4 class="quiz-title mb-0"><%= quiz.title %></h4>
                    <div class="quiz-meta">
                        <%= quiz.question_count %> Questions |
                        <%= quiz.quiz_type.toUpperCase() %>
                    </div>
                    <div class="progress-row">
                        <div class="progress">
                            <div class="progress-bar" id="progressBar" style="width: 0%"></div>
                        </div>
                        <span class="progress-label">Progress</span>
                    </div>
                </div>
                <div class="timer-card">
                    <div class="timer-icon" aria-hidden="true">&#9201;</div>
                    <div class="timer-heading">TIME REMAINING</div>
                    <div id="timer">
                        <span id="timerDisplay"><%= typeof timerMinutes !== 'undefined' ? timerMinutes : 10 %>:00</span>
                    </div>
                    <small class="progress-tracker" id="progressText">0 / <%= quiz.questions.length %> answered</small>
                </div>
            </div>
        </div>

        <!-- Quiz Form -->
        <form action="/quizzes/<%= quiz.id %>/submit" method="POST" id="quizForm">
            <% quiz.questions.forEach((q, index) => { %>
                <div class="card mb-3 question-card" id="card-<%= index %>">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">Question <%= index + 1 %></h5>
                            <span class="badge bg-<%= q.type === 'mcq' ? 'primary' : q.type === 'true_false' ? 'info' : 'warning' %>">
                                <%= q.type === 'mcq' ? 'MCQ' : q.type === 'true_false' ? 'True/False' : 'Short Answer' %>
                            </span>
                        </div>
                        <p class="card-text fs-6"><%= q.question %></p>

                        <% if (q.type === 'mcq' && q.options) { %>
                            <% q.options.forEach((opt, optIndex) => { %>
                                <div class="form-check mb-2">
                                    <input class="form-check-input answer-input" type="radio"
                                        name="answers[q<%= index %>]"
                                        value="<%= String.fromCharCode(65 + optIndex) %>"
                                        id="q<%= index %>_<%= optIndex %>"
                                        data-question="<%= index %>">
                                    <label class="form-check-label" for="q<%= index %>_<%= optIndex %>">
                                        <strong><%= String.fromCharCode(65 + optIndex) %>.</strong> <%= opt %>
                                    </label>
                                </div>
                            <% }) %>
                        <% } else if (q.type === 'true_false') { %>
                            <div class="form-check mb-2">
                                <input class="form-check-input answer-input" type="radio"
                                    name="answers[q<%= index %>]" value="A"
                                    id="q<%= index %>_true" data-question="<%= index %>">
                                <label class="form-check-label" for="q<%= index %>_true">
                                    <strong>A.</strong> True
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input answer-input" type="radio"
                                    name="answers[q<%= index %>]" value="B"
                                    id="q<%= index %>_false" data-question="<%= index %>">
                                <label class="form-check-label" for="q<%= index %>_false">
                                    <strong>B.</strong> False
                                </label>
                            </div>
                        <% } else { %>
                            <textarea name="answers[q<%= index %>]" class="form-control answer-input"
                                rows="3" placeholder="Type your answer here..."
                                data-question="<%= index %>"></textarea>
                        <% } %>
                    </div>
                </div>
            <% }) %>

            <div class="d-flex justify-content-between mt-4 mb-4">
                <a href="/quizzes" class="btn btn-secondary">← Back to Quizzes</a>
                <button type="submit" class="btn btn-success btn-lg" id="submitBtn">
                    ✅ Submit Quiz
                </button>
            </div>
        </form>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Timer
        const totalMinutes = <%= typeof timerMinutes !== 'undefined' ? timerMinutes : 10 %>;
        let timeRemaining = totalMinutes * 60;
        const timerDisplay = document.getElementById('timerDisplay');
        const timerContainer = document.getElementById('timer');

        const timerInterval = setInterval(() => {
            timeRemaining--;
            const mins = Math.floor(timeRemaining / 60);
            const secs = timeRemaining % 60;
            timerDisplay.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;

            // Warning at 2 minutes
            if (timeRemaining <= 120) {
                timerContainer.classList.add('timer-warning');
            }

            // Auto-submit when time's up
            if (timeRemaining <= 0) {
                clearInterval(timerInterval);
                alert('Time is up! Your quiz will be submitted now.');
                document.getElementById('quizForm').submit();
            }
        }, 1000);

        // Progress tracking
        const totalQuestions = <%= quiz.questions.length %>;
        const answeredSet = new Set();

        document.querySelectorAll('.answer-input').forEach(input => {
            const event = input.tagName === 'TEXTAREA' ? 'input' : 'change';
            input.addEventListener(event, function() {
                const qIndex = this.dataset.question;
                const value = this.type === 'radio' ? this.value : this.value.trim();

                if (value) {
                    answeredSet.add(qIndex);
                    document.getElementById('card-' + qIndex).classList.add('answered');
                } else {
                    answeredSet.delete(qIndex);
                    document.getElementById('card-' + qIndex).classList.remove('answered');
                }

                // Update progress
                const answered = answeredSet.size;
                const percent = Math.round((answered / totalQuestions) * 100);
                document.getElementById('progressBar').style.width = percent + '%';
                document.getElementById('progressText').textContent = `${answered} / ${totalQuestions} answered`;
            });
        });

        // Confirm before leaving
        window.addEventListener('beforeunload', function(e) {
            e.preventDefault();
            e.returnValue = '';
        });

        // Remove beforeunload on submit
        document.getElementById('quizForm').addEventListener('submit', function() {
            window.removeEventListener('beforeunload', function() {});
        });
    </script>
</body>
</html>
