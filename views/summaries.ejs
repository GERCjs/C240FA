<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Summaries - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Study Summaries</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal"
                {% if documents is not defined or documents|length == 0 %}disabled{% endif %}>
                + Generate Summary
            </button>
        </div>

        {% if documents is not defined or documents|length == 0 %}
            <div class="alert alert-info">Upload a document first before generating summaries.</div>
        {% endif %}

        {% if summaries is defined and summaries|length > 0 %}
            <div class="row g-3">
                {% for s in summaries %}
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5>{{ s.title }}</h5>
                                <p class="text-muted">{{ s.document_name or 'Manual' }}</p>
                                <p>{{ s.summary_text[:150] }}...</p>
                            </div>
                            <div class="card-footer">
                                <a href="/summaries/{{ s.id }}" class="btn btn-sm btn-primary">View</a>
                                <a href="/summaries/{{ s.id }}/export" class="btn btn-sm btn-outline-secondary">Export</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center text-muted py-5">
                <h4>No summaries yet</h4>
                <p>Generate revision notes from your uploaded documents.</p>
            </div>
        {% endif %}
    </div>

    <div class="modal fade" id="generateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/summaries/generate" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Generate Summary</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Document</label>
                            <select name="document_id" class="form-select" required>
                                {% if documents is defined %}
                                    {% for d in documents %}
                                        <option value="{{ d.id }}">{{ d.original_name }}</option>
                                    {% endfor %}
                                {% endif %}
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Generate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
