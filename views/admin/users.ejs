<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <div class="container py-4 flex-grow-1">
        <h2 class="mb-4">Manage Users</h2>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Chats</th>
                        <th>Quizzes</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for u in users %}
                        <tr>
                            <td>{{ u.id }}</td>
                            <td>{{ u.name }}</td>
                            <td>{{ u.email }}</td>
                            <td><span class="badge bg-{{ 'danger' if u.role == 'admin' else 'primary' }}">{{ u.role }}</span></td>
                            <td>{{ u.chat_count }}</td>
                            <td>{{ u.quiz_count }}</td>
                            <td>{{ u.created_at|date }}</td>
                            <td>
                                {% if u.role != 'admin' %}
                                    <form action="/admin/users/{{ u.id }}/delete" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this user?')">Delete</button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
