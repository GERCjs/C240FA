<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <div class="container py-4 flex-grow-1">
        <h2 class="mb-4">Analytics</h2>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">Quiz Statistics</div>
                    <div class="card-body">
                        <table class="table">
                            <tr><td>Total Attempts</td><td><strong>{{ quizStats.total_attempts or 0 }}</strong></td></tr>
                            <tr><td>Average Score</td><td><strong>{{ (quizStats.avg_score or 0)|round|int }}%</strong></td></tr>
                            <tr><td>Highest Score</td><td><strong>{{ quizStats.highest_score or 0 }}%</strong></td></tr>
                            <tr><td>Lowest Score</td><td><strong>{{ quizStats.lowest_score or 0 }}%</strong></td></tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">Messages Per Day</div>
                    <div class="card-body">
                        {% if chatData|length > 0 %}
                            <table class="table">
                                <thead><tr><th>Date</th><th>Messages</th></tr></thead>
                                <tbody>
                                    {% for d in chatData %}
                                        <tr><td>{{ d.date|date }}</td><td>{{ d.count }}</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <p class="text-muted">No chat data yet.</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-info text-white">Most Active Users</div>
                    <div class="card-body">
                        {% if activeUsers|length > 0 %}
                            <table class="table">
                                <thead><tr><th>User</th><th>Messages</th></tr></thead>
                                <tbody>
                                    {% for u in activeUsers %}
                                        <tr><td>{{ u.name }}</td><td>{{ u.message_count }}</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <p class="text-muted">No active users yet.</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
