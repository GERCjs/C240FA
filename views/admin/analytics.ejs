<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('../partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <h2>📊 Usage Analytics</h2>
        <a href="/admin" class="btn btn-sm btn-outline-secondary mb-3">← Back to Admin</a>

        <div class="row g-4">
            <!-- Quiz Statistics -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Quiz Statistics</h5>
                    </div>
                    <div class="card-body">
                        <table class="table mb-0">
                            <tr><td>Total Attempts</td><td><strong><%= quizStats.total_attempts || 0 %></strong></td></tr>
                            <tr><td>Average Score</td><td><strong><%= Math.round(quizStats.avg_score || 0) %>%</strong></td></tr>
                            <tr><td>Highest Score</td><td><strong><%= quizStats.highest_score || 0 %>%</strong></td></tr>
                            <tr><td>Lowest Score</td><td><strong><%= quizStats.lowest_score || 0 %>%</strong></td></tr>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Chat Activity (Last 7 Days) -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Chat Activity (Last 7 Days)</h5>
                    </div>
                    <div class="card-body">
                        <% if (chatData.length > 0) { %>
                            <table class="table mb-0">
                                <thead><tr><th>Date</th><th>Messages</th></tr></thead>
                                <tbody>
                                    <% chatData.forEach(d => { %>
                                        <tr>
                                            <td><%= new Date(d.date).toLocaleDateString() %></td>
                                            <td><%= d.count %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <p class="text-muted mb-0">No chat activity in the last 7 days.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Most Active Users -->
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Most Active Users</h5>
                    </div>
                    <div class="card-body">
                        <% if (activeUsers.length > 0) { %>
                            <table class="table mb-0">
                                <thead><tr><th>User</th><th>Messages Sent</th></tr></thead>
                                <tbody>
                                    <% activeUsers.forEach(u => { %>
                                        <tr>
                                            <td><%= u.name %></td>
                                            <td><%= u.message_count %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <p class="text-muted mb-0">No user activity data yet.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
