<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('../partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <h2>🔧 Admin Dashboard</h2>
        <nav class="mb-4">
            <a href="/admin/users" class="btn btn-outline-primary me-2">Manage Users</a>
            <a href="/admin/documents" class="btn btn-outline-primary me-2">Manage Documents</a>
            <a href="/admin/analytics" class="btn btn-outline-primary">Analytics</a>
        </nav>

        <div class="row g-3">
            <div class="col-md-3">
                <div class="card bg-primary text-white text-center">
                    <div class="card-body">
                        <h3><%= stats.total_users || 0 %></h3>
                        <p class="mb-0">Users</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white text-center">
                    <div class="card-body">
                        <h3><%= stats.total_messages || 0 %></h3>
                        <p class="mb-0">Messages</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white text-center">
                    <div class="card-body">
                        <h3><%= stats.total_documents || 0 %></h3>
                        <p class="mb-0">Documents</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark text-center">
                    <div class="card-body">
                        <h3><%= stats.total_attempts || 0 %></h3>
                        <p class="mb-0">Quiz Attempts</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
