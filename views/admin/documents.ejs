<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Documents - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    {% include 'partial/navbar.ejs' %}

    <div class="container py-4 flex-grow-1">
        <h2 class="mb-4">Manage Documents</h2>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Uploader</th>
                        <th>Type</th>
                        <th>Size</th>
                        <th>Indexed</th>
                        <th>Uploaded</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for d in documents %}
                        <tr>
                            <td>{{ d.id }}</td>
                            <td>{{ d.original_name }}</td>
                            <td>{{ d.uploader_name }}</td>
                            <td>{{ d.file_type }}</td>
                            <td>{{ d.file_size|kb }} KB</td>
                            <td>{{ 'Yes' if d.indexed else 'No' }}</td>
                            <td>{{ d.created_at|date }}</td>
                            <td>
                                <form action="/admin/documents/{{ d.id }}/delete" method="POST" class="d-inline">
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this document?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'partial/footer.ejs' %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
