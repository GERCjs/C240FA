<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flashcards - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>🃏 Flashcards</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateModal">+ Generate Cards</button>
        </div>

        <% if (typeof flashcards !== 'undefined' && flashcards.length > 0) { %>
            <%
                // Group flashcards by topic
                const grouped = {};
                flashcards.forEach(card => {
                    const key = card.topic || 'General';
                    if (!grouped[key]) grouped[key] = [];
                    grouped[key].push(card);
                });
                const topics = Object.keys(grouped);
            %>

            <!-- Topic filter tabs -->
            <ul class="nav nav-pills mb-4" id="topicTabs">
                <li class="nav-item">
                    <a class="nav-link active" href="#" data-topic="all">All (<%= flashcards.length %>)</a>
                </li>
                <% topics.forEach(topic => { %>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-topic="<%= topic %>"><%= topic %> (<%= grouped[topic].length %>)</a>
                    </li>
                <% }) %>
            </ul>

            <!-- Flashcards grouped by topic -->
            <% topics.forEach(topic => { %>
                <div class="topic-group mb-4" data-topic-group="<%= topic %>">
                    <h5 class="text-muted border-bottom pb-2 mb-3"><%= topic %></h5>
                    <div class="row g-3">
                        <% grouped[topic].forEach(card => { %>
                            <div class="col-md-4">
                                <div class="card h-100 flashcard" onclick="flipCard(this, event)">
                                    <div class="card-body text-center d-flex flex-column justify-content-center position-relative" style="min-height: 200px;">
                                        <!-- Delete button -->
                                        <form action="/flashcards/<%= card.id %>/delete" method="POST" class="position-absolute top-0 end-0 m-2" onclick="event.stopPropagation()">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete card" onclick="return confirm('Delete this flashcard?')">✕</button>
                                        </form>

                                        <div class="flashcard-front">
                                            <small class="text-muted d-block mb-2"><%= card.subject %> - <%= card.topic %></small>
                                            <p class="fw-bold"><%= card.front_text %></p>
                                            <small class="text-muted">Click to reveal</small>
                                        </div>
                                        <div class="flashcard-back d-none">
                                            <p><%= card.back_text %></p>
                                            <small class="text-muted">Reviewed <%= card.times_reviewed %> time(s)</small>
                                            <form action="/flashcards/<%= card.id %>/review" method="POST" class="mt-2" onclick="event.stopPropagation()">
                                                <button class="btn btn-sm btn-success">✓ Mark Reviewed</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="text-center text-muted py-5">
                <h4>No flashcards yet</h4>
                <p>Generate flashcards from your study topics or documents.</p>
            </div>
        <% } %>
    </div>

    <!-- Generate Modal -->
    <div class="modal fade" id="generateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/flashcards/generate" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Generate Flashcards</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <select name="subject" class="form-select">
                                <option value="Programming">Programming</option>
                                <option value="Database">Database</option>
                                <option value="AI Prompting">AI Prompting</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Topic</label>
                            <input type="text" name="topic" class="form-control" placeholder="e.g. Python Basics">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">From Document (optional)</label>
                            <select name="document_id" class="form-select">
                                <option value="">-- None --</option>
                                <% if (typeof documents !== 'undefined') { %>
                                    <% documents.forEach(d => { %>
                                        <option value="<%= d.id %>"><%= d.original_name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Generate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Flashcard flip
        function flipCard(card, event) {
            const front = card.querySelector('.flashcard-front');
            const back = card.querySelector('.flashcard-back');
            front.classList.toggle('d-none');
            back.classList.toggle('d-none');
        }

        // Topic filter
        document.querySelectorAll('#topicTabs .nav-link').forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();

                // Update active tab
                document.querySelectorAll('#topicTabs .nav-link').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const selectedTopic = tab.dataset.topic;
                const groups = document.querySelectorAll('.topic-group');

                groups.forEach(group => {
                    if (selectedTopic === 'all' || group.dataset.topicGroup === selectedTopic) {
                        group.style.display = '';
                    } else {
                        group.style.display = 'none';
                    }
                });
            });
        });
    </script>
</body>
</html>
