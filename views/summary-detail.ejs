<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= summary.title %> - Study Buddy AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partial/navbar') %>

    <div class="container py-4 flex-grow-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><%= summary.title %></h2>
            <a href="/summaries/<%= summary.id %>/export" class="btn btn-outline-primary">📥 Export</a>
        </div>

        <% if (summary.document_name) { %>
            <p class="text-muted">Source: <%= summary.document_name %></p>
        <% } %>

        <div class="card mb-4">
            <div class="card-header"><h5>Summary</h5></div>
            <div class="card-body">
                <pre style="white-space: pre-wrap;"><%= summary.summary_text %></pre>
            </div>
        </div>

        <% if (summary.key_points && summary.key_points.length > 0) { %>
            <div class="card mb-4">
                <div class="card-header"><h5>Key Points</h5></div>
                <div class="card-body">
                    <ol>
                        <% summary.key_points.forEach(p => { %>
                            <li><%= p %></li>
                        <% }) %>
                    </ol>
                </div>
            </div>
        <% } %>

        <a href="/summaries" class="btn btn-secondary">← Back to Summaries</a>
    </div>

    <%- include('partial/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
